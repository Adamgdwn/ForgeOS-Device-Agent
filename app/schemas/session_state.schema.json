{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ForgeOS Session State",
  "type": "object",
  "required": [
    "session_id",
    "state",
    "history",
    "priority_order",
    "destructive_actions_approved",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "session_id": { "type": "string" },
    "state": { "type": "string" },
    "history": {
      "type": "array",
      "items": { "type": "object" }
    },
    "priority_order": {
      "type": "array",
      "items": { "type": "string" }
    },
    "destructive_actions_approved": { "type": "boolean" },
    "selected_strategy": { "type": ["string", "null"] },
    "support_status": {
      "type": "string",
      "enum": ["actionable", "research_only", "blocked", "experimental"]
    },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}
