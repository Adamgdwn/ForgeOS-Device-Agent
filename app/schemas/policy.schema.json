{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ForgeOS Policy",
  "type": "object",
  "required": [
    "policy_version",
    "default_dry_run",
    "require_restore_path",
    "priority_order"
  ],
  "properties": {
    "policy_version": { "type": "string" },
    "default_dry_run": { "type": "boolean" },
    "require_restore_path": { "type": "boolean" },
    "allow_bootloader_relock": { "type": "boolean" },
    "open_vscode_on_launch": { "type": "boolean" },
    "open_vscode_on_session_create": { "type": "boolean" },
    "priority_order": {
      "type": "array",
      "items": { "type": "string" }
    },
    "host_requirements": { "type": "object" }
  },
  "additionalProperties": true
}
